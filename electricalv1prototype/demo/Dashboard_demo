# 2. WRITE FUNCTION (ThingSpeak)
# ==============================
def push_to_thingspeak():
    mode = 1 if master_switch_var.get() else 2
    red, green, blue = r_var.get(), g_var.get(), b_var.get()

    rgb_val_var.set(f"{red}, {green}, {blue}")
    led_state_var.set("ON" if mode else "OFF")

    url = (f"https://api.thingspeak.com/update?api_key={WRITE_API_KEY}"
           f"&field1={mode}&field2={red}&field3={green}&field4={blue}"
           f"&field5={encoded_bus_payload}")

    try:
        with urllib.request.urlopen(url) as response:
            result = response.read().decode('utf-8')
            if result != "0":
                messagebox.showinfo("Success", f"Update Successful! Entry ID: {result}")
            else:
                messagebox.showwarning("Warning", "Rate limit hit (wait 15 seconds).")
    except Exception as e:
        messagebox.showerror("Error", f"Connection Error:\n{e}")

# ==============================
# 3. READ & LOG FUNCTION
# ==============================
def read_battery_data():
    url = f"https://api.thingspeak.com/channels/{READ_CHANNEL_ID}/feeds.json?api_key={READ_API_KEY}&results=1"
    try:
        with urllib.request.urlopen(url) as response:
            data = json.loads(response.read().decode())
            if "feeds" in data and len(data["feeds"]) > 0:
                feed = data["feeds"][0]
                
                raw_v_batt, raw_soc, raw_i_batt = feed.get("field1"), feed.get("field2"), feed.get("field3")
                raw_v_gen, raw_i_gen = feed.get("field4"), feed.get("field5")
                status = feed.get("field7", "N/A")
                
                # --- ACTUAL FORMAT CONVERSION ---
                v_batt_real = float(raw_v_batt) / 10.0 if raw_v_batt else 0.0
                i_batt_real = float(raw_i_batt) / 10.0 if raw_i_batt else 0.0
                v_gen_real = float(raw_v_gen) / 10.0 if raw_v_gen else 0.0
                i_gen_real = float(raw_i_gen) / 10.0 if raw_i_gen else 0.0
                soc_real = float(raw_soc) if raw_soc else 0.0

                p_batt_real = v_batt_real * i_batt_real
                p_gen_real = v_gen_real * i_gen_real

                # --- SET UI VARIABLES ---
                battery_voltage.set(f"{v_batt_real:.2f} V" if raw_v_batt else "N/A")
                battery_current.set(f"{i_batt_real:.2f} A" if raw_i_batt else "N/A")
                Wind_voltage.set(f"{v_gen_real:.2f} V" if raw_v_gen else "N/A")
                soc.set(f"{soc_real:.1f} %" if raw_soc else "N/A")
                bms_status.set(status)
                battery_power.set(f"{p_batt_real:.2f} W" if raw_v_batt and raw_i_batt else "N/A")
                Wind_power.set(f"{p_gen_real:.2f} W" if raw_v_gen and raw_i_gen else "N/A")
                
                # --- LOG TO CSV ---
                timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                with open(CSV_FILE, 'a', newline='') as f:
                    writer = csv.writer(f)
                    writer.writerow([
                        timestamp, round(v_batt_real, 2), round(i_batt_real, 2), 
                        round(p_batt_real, 2), round(v_gen_real, 2), round(p_gen_real, 2), round(soc_real, 1)
                    ])
                
                # Update Graph with new data
                update_graph()

    except Exception as e:
        print(f"Background refresh failed: {e}") 

    # Loop every 30 seconds
    root.after(30000, read_battery_data)
