# 1. SCRAPER FUNCTION
# ==============================
def find_top_3_buses():
    bus_scrape_btn.config(text="Scraping...", bg="orange")
    root.update()

    all_buses = []
    now = datetime.now()

    for bus_name, stop_no in STOPS.items():
        url = f"http://www.transitdb.ca/nextbus/{stop_no}/"
        try:
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req, timeout=5) as response:
                html = response.read().decode('utf-8')
                times = re.findall(r'<td>(\d{1,2}:\d{2})</td>', html)
                
                for time_str in times:
                    time_obj = datetime.strptime(time_str, "%H:%M")
                    bus_time = now.replace(hour=time_obj.hour, minute=time_obj.minute, second=0, microsecond=0)
                    
                    delta_minutes = (bus_time - now).total_seconds() / 60
                    if delta_minutes < -60:
                        bus_time += timedelta(days=1)
                        delta_minutes = (bus_time - now).total_seconds() / 60
                        
                    countdown = int(delta_minutes)
                    if countdown >= -2:
                        time_hhmm = time_str.replace(":", "")
                        all_buses.append({'name': bus_name, 'time_hhmm': time_hhmm, 'countdown': countdown})
        except Exception:
            pass 

    all_buses.sort(key=lambda x: x['countdown'])
    top_3 = all_buses[:3]

    bus1_var.set("Route: ---  |  Time: ---")
    bus2_var.set("Route: ---  |  Time: ---")
    bus3_var.set("Route: ---  |  Time: ---")

    if len(top_3) >= 1: bus1_var.set(f"Route: {top_3[0]['name']}  |  Time: {top_3[0]['time_hhmm']} ({top_3[0]['countdown']}m)")
    if len(top_3) >= 2: bus2_var.set(f"Route: {top_3[1]['name']}  |  Time: {top_3[1]['time_hhmm']} ({top_3[1]['countdown']}m)")
    if len(top_3) >= 3: bus3_var.set(f"Route: {top_3[2]['name']}  |  Time: {top_3[2]['time_hhmm']} ({top_3[2]['countdown']}m)")

    json_data = [{"sno": i + 1, "name": bus['name'], "route": "Outbnd", "time": bus['time_hhmm']} for i, bus in enumerate(top_3)]
    
    global encoded_bus_payload
    encoded_bus_payload = urllib.parse.quote(json.dumps(json_data, separators=(',', ':')))
    bus_scrape_btn.config(text="Scrape Live Buses", bg="#f0f0f0")

