# 4. GRAPHING FUNCTION
# ==============================
def update_graph(*args):
    param = param_var.get()
    Window_str = Window_var.get()
    now = datetime.now()
    
    # Map selection to timedelta
    time_deltas = {
        "10 Minutes": timedelta(minutes=10),
        "1 Hour": timedelta(hours=1),
        "6 Hours": timedelta(hours=6),
        "1 Day": timedelta(days=1),
        "1 Week": timedelta(weeks=1),
        "1 Month": timedelta(days=30),
        "1 Year": timedelta(days=365)
    }
    
    # Define bucketing interval (in seconds) to prevent graph overcrowding
    # 0 = Use raw 30-second data points
    bucket_intervals = {
        "10 Minutes": 0,             # Raw points
        "1 Hour": 0,                 # Raw points
        "6 Hours": 5 * 60,           # Average every 5 minutes
        "1 Day": 30 * 60,            # Average every 30 minutes
        "1 Week": 4 * 3600,          # Average every 4 hours
        "1 Month": 24 * 3600,        # Average every 1 day
        "1 Year": 7 * 24 * 3600      # Average every 1 week
    }
    
    cutoff_time = now - time_deltas[Window_str]
    interval = bucket_intervals[Window_str]
    
    times, values = [], []
    bucketed_data = {}
    
    try:
        with open(CSV_FILE, 'r') as f:
            reader = csv.DictReader(f)
            for row in reader:
                try:
                    row_time = datetime.strptime(row["Timestamp"], "%Y-%m-%d %H:%M:%S")
                    if row_time >= cutoff_time:
                        val = float(row[param])
                        
                        if interval == 0:
                            times.append(row_time)
                            values.append(val)
                        else:
                            # Group data points into time buckets
                            ts = row_time.timestamp()
                            bucket_ts = ts - (ts % interval)
                            if bucket_ts not in bucketed_data:
                                bucketed_data[bucket_ts] = []
                            bucketed_data[bucket_ts].append(val)
                except (ValueError, KeyError):
                    continue
    except FileNotFoundError:
        pass

    # Process bucketed data by calculating the average for each interval
    if interval > 0:
        for b_ts in sorted(bucketed_data.keys()):
            times.append(datetime.fromtimestamp(b_ts))
            avg_val = sum(bucketed_data[b_ts]) / len(bucketed_data[b_ts])
            values.append(avg_val)

    # Clear and redraw plot
    ax.clear()
    
    if times:
        ax.plot(times, values, marker='.', linestyle='-', color='#1f77b4', markersize=4)
        
    # --- NEW: Force the X-Axis to span the ENTIRE selected time Window ---
    # This ensures blank space is shown on the left if no historical data exists
    ax.set_xlim(cutoff_time, now)

    ax.set_title(f"{param} (Last {Window_str})", fontsize=10)
    ax.set_ylabel(param.split(' ')[-1].replace('(','').replace(')',''), fontsize=9)
    ax.grid(True, linestyle='--', alpha=0.6)
    
    # Dynamic X-Axis Formatting
    if Window_str in ["10 Minutes", "1 Hour"]:
        date_fmt = mdates.DateFormatter('%H:%M:%S') 
    elif Window_str in ["6 Hours", "1 Day"]:
        date_fmt = mdates.DateFormatter('%H:%M')    
    elif Window_str in ["1 Week", "1 Month"]:
        date_fmt = mdates.DateFormatter('%b %d, %H:%M') 
    else: 
        date_fmt = mdates.DateFormatter('%b %Y')    
        
    ax.xaxis.set_major_formatter(date_fmt)
    
    # Prevent overlapping text labels
    locator = mdates.AutoDateLocator(minticks=4, maxticks=8)
    ax.xaxis.set_major_locator(locator)
    
    plt.setp(ax.get_xticklabels(), rotation=30, ha='right', fontsize=8)
    fig.tight_layout()

    canvas.draw()

